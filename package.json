{
  "name": "dpd-sdk",
  "type": "module",
  "private": true,
  "scripts": {
    "generate": "bun ./gen/release.ts",
    "generate:offline": "bun ./gen/release.ts --offline",
    "docs:build": "rm -rf _site && mkdir -p _site && cp docs/index.html _site/index.html && cp openapi.yaml _site/openapi.yaml",
    "docs:preview": "bun run docs:build && bunx serve _site"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/cheerio": "^1.0.0",
    "cheerio": "^1.1.0",
    "openapi-types": "^12.1.3"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "cross-fetch": "^4.1.0",
    "parse5": "^8.0.0",
    "yaml": "^2.5.0"
  }
}
